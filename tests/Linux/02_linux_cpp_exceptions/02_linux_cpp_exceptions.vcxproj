<?xml version="1.0" encoding="utf-8"?>
<!-- NMakefile project: cross-compiles 02_linux_cpp_exceptions/main.cpp via MinGW g++-posix.
     Requires g++-mingw-w64-x86-64 / g++-mingw-w64-i686 in PATH.
     Uses peor_crtbegin.c, peor_crtend.c, and seh_linux64.c / freestanding.c from cpp_eh_support/. -->
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|Win32">
      <Configuration>Debug</Configuration>
      <Platform>Win32</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|Win32">
      <Configuration>Release</Configuration>
      <Platform>Win32</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>
  <PropertyGroup Label="Globals">
    <VCProjectVersion>17.0</VCProjectVersion>
    <ProjectGuid>{BBBB0002-0002-0002-0002-000000000002}</ProjectGuid>
    <Keyword>MakeFileProj</Keyword>
    <RootNamespace>linux_cpp_exceptions</RootNamespace>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />
  <!-- x86 Debug -->
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|Win32'" Label="Configuration">
    <ConfigurationType>Makefile</ConfigurationType>
    <OutDir>$(SolutionDir)Linux_x86\</OutDir>
    <NMakeBuildCommandLine>
      i686-w64-mingw32-g++-posix -x c -fexceptions -c $(SolutionDir)cpp_eh_support\peor_crtbegin.c -o peor_crtbegin_x86.o &amp;&amp;
      i686-w64-mingw32-g++-posix -x c -fexceptions -c $(SolutionDir)cpp_eh_support\peor_crtend.c -o peor_crtend_x86.o &amp;&amp;
      i686-w64-mingw32-g++-posix -x c -fexceptions -DPEOR_EFI -c $(SolutionDir)cpp_eh_support\freestanding.c -o freestanding_x86.o &amp;&amp;
      i686-w64-mingw32-g++-posix -fexceptions -nostartfiles -nodefaultlibs peor_crtbegin_x86.o freestanding_x86.o main.cpp -Wl,--start-group -lgcc_eh -lsupc++ -lgcc -Wl,--end-group peor_crtend_x86.o -Wl,-e,_main -Wl,--subsystem,posix -o $(OutDir)02_linux_cpp_exceptions_x86.pe &amp;&amp;
      del peor_crtbegin_x86.o peor_crtend_x86.o freestanding_x86.o 2&gt;nul
    </NMakeBuildCommandLine>
    <NMakeOutput>$(OutDir)02_linux_cpp_exceptions_x86.pe</NMakeOutput>
    <NMakeCleanCommandLine>del /f $(OutDir)02_linux_cpp_exceptions_x86.pe 2&gt;nul</NMakeCleanCommandLine>
  </PropertyGroup>
  <!-- x86 Release -->
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|Win32'" Label="Configuration">
    <ConfigurationType>Makefile</ConfigurationType>
    <OutDir>$(SolutionDir)Linux_x86\</OutDir>
    <NMakeBuildCommandLine>
      i686-w64-mingw32-g++-posix -x c -fexceptions -c $(SolutionDir)cpp_eh_support\peor_crtbegin.c -o peor_crtbegin_x86.o &amp;&amp;
      i686-w64-mingw32-g++-posix -x c -fexceptions -c $(SolutionDir)cpp_eh_support\peor_crtend.c -o peor_crtend_x86.o &amp;&amp;
      i686-w64-mingw32-g++-posix -x c -fexceptions -DPEOR_EFI -c $(SolutionDir)cpp_eh_support\freestanding.c -o freestanding_x86.o &amp;&amp;
      i686-w64-mingw32-g++-posix -O2 -fexceptions -nostartfiles -nodefaultlibs peor_crtbegin_x86.o freestanding_x86.o main.cpp -Wl,--start-group -lgcc_eh -lsupc++ -lgcc -Wl,--end-group peor_crtend_x86.o -Wl,-e,_main -Wl,--subsystem,posix -o $(OutDir)02_linux_cpp_exceptions_x86.pe &amp;&amp;
      del peor_crtbegin_x86.o peor_crtend_x86.o freestanding_x86.o 2&gt;nul
    </NMakeBuildCommandLine>
    <NMakeOutput>$(OutDir)02_linux_cpp_exceptions_x86.pe</NMakeOutput>
    <NMakeCleanCommandLine>del /f $(OutDir)02_linux_cpp_exceptions_x86.pe 2&gt;nul</NMakeCleanCommandLine>
  </PropertyGroup>
  <!-- x64 Debug -->
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'" Label="Configuration">
    <ConfigurationType>Makefile</ConfigurationType>
    <OutDir>$(SolutionDir)Linux_x64\</OutDir>
    <NMakeBuildCommandLine>
      x86_64-w64-mingw32-g++-posix -x c -fexceptions -c $(SolutionDir)cpp_eh_support\peor_crtbegin.c -o peor_crtbegin_x64.o &amp;&amp;
      x86_64-w64-mingw32-g++-posix -x c -fexceptions -c $(SolutionDir)cpp_eh_support\peor_crtend.c -o peor_crtend_x64.o &amp;&amp;
      x86_64-w64-mingw32-g++-posix -x c -fexceptions -DPEOR_LINUX_SEH -c $(SolutionDir)cpp_eh_support\seh_linux64.c -o seh_linux64_x64.o &amp;&amp;
      x86_64-w64-mingw32-g++-posix -fexceptions -nostartfiles -nodefaultlibs -Wl,--disable-auto-import peor_crtbegin_x64.o seh_linux64_x64.o main.cpp -Wl,--start-group -lgcc_eh -lsupc++ -lgcc -Wl,--end-group peor_crtend_x64.o -Wl,-e,main -Wl,--subsystem,posix -o $(OutDir)02_linux_cpp_exceptions_x64.pe &amp;&amp;
      del peor_crtbegin_x64.o peor_crtend_x64.o seh_linux64_x64.o 2&gt;nul
    </NMakeBuildCommandLine>
    <NMakeOutput>$(OutDir)02_linux_cpp_exceptions_x64.pe</NMakeOutput>
    <NMakeCleanCommandLine>del /f $(OutDir)02_linux_cpp_exceptions_x64.pe 2&gt;nul</NMakeCleanCommandLine>
  </PropertyGroup>
  <!-- x64 Release -->
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'" Label="Configuration">
    <ConfigurationType>Makefile</ConfigurationType>
    <OutDir>$(SolutionDir)Linux_x64\</OutDir>
    <NMakeBuildCommandLine>
      x86_64-w64-mingw32-g++-posix -x c -fexceptions -c $(SolutionDir)cpp_eh_support\peor_crtbegin.c -o peor_crtbegin_x64.o &amp;&amp;
      x86_64-w64-mingw32-g++-posix -x c -fexceptions -c $(SolutionDir)cpp_eh_support\peor_crtend.c -o peor_crtend_x64.o &amp;&amp;
      x86_64-w64-mingw32-g++-posix -x c -fexceptions -DPEOR_LINUX_SEH -c $(SolutionDir)cpp_eh_support\seh_linux64.c -o seh_linux64_x64.o &amp;&amp;
      x86_64-w64-mingw32-g++-posix -O2 -fexceptions -nostartfiles -nodefaultlibs -Wl,--disable-auto-import peor_crtbegin_x64.o seh_linux64_x64.o main.cpp -Wl,--start-group -lgcc_eh -lsupc++ -lgcc -Wl,--end-group peor_crtend_x64.o -Wl,-e,main -Wl,--subsystem,posix -o $(OutDir)02_linux_cpp_exceptions_x64.pe &amp;&amp;
      del peor_crtbegin_x64.o peor_crtend_x64.o seh_linux64_x64.o 2&gt;nul
    </NMakeBuildCommandLine>
    <NMakeOutput>$(OutDir)02_linux_cpp_exceptions_x64.pe</NMakeOutput>
    <NMakeCleanCommandLine>del /f $(OutDir)02_linux_cpp_exceptions_x64.pe 2&gt;nul</NMakeCleanCommandLine>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <ImportGroup Label="ExtensionSettings">
  </ImportGroup>
  <ImportGroup Label="Shared">
  </ImportGroup>
  <ImportGroup Label="PropertySheets" Condition="'$(Configuration)|$(Platform)'=='Debug|Win32'">
    <Import Project="$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props" Condition="exists('$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props')" Label="LocalAppDataPlatform" />
  </ImportGroup>
  <ImportGroup Label="PropertySheets" Condition="'$(Configuration)|$(Platform)'=='Release|Win32'">
    <Import Project="$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props" Condition="exists('$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props')" Label="LocalAppDataPlatform" />
  </ImportGroup>
  <ImportGroup Label="PropertySheets" Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <Import Project="$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props" Condition="exists('$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props')" Label="LocalAppDataPlatform" />
  </ImportGroup>
  <ImportGroup Label="PropertySheets" Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <Import Project="$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props" Condition="exists('$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props')" Label="LocalAppDataPlatform" />
  </ImportGroup>
  <PropertyGroup Label="UserMacros" />
  <ItemGroup>
    <ClCompile Include="main.cpp" />
  </ItemGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
  <ImportGroup Label="ExtensionTargets">
  </ImportGroup>
</Project>
